{
    "name": "banulakwin/filament-pwa",
    "description": "Filament PWA, web push, mobile bottom nav styling, and global search modal integration for Laravel.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "filament", "pwa", "web-push", "admin"],
    "homepage": "https://github.com/banulalakwindu/filament-pwa",
    "support": {
        "issues": "https://github.com/banulalakwindu/filament-pwa/issues",
        "source": "https://github.com/banulalakwindu/filament-pwa"
    },
    "require": {
        "php": "^8.4",
        "filament/filament": "^5.0",
        "minishlink/web-push": "^10.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/notifications": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "suggest": {
        "charrafimed/global-search-modal": "Required for the mobile global search render hook (GlobalSearchModalPlugin on the same panel).",
        "hammadzafar05/mobile-bottom-nav": "Required when publishing the optional glass bottom navigation view override."
    },
    "require-dev": {
        "laravel/pint": "^1.21",
        "orchestra/testbench": "^10.0|^11.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Banulakwin\\FilamentPwa\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Banulakwin\\FilamentPwa\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Banulakwin\\FilamentPwa\\FilamentPwaServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist"
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage",
        "pint": "pint",
        "pint:check": "pint --test",
        "phpstan": "phpstan analyse",
        "analyse": "@phpstan",
        "quality": ["@pint", "@phpstan", "@test"]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
